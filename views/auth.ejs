<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ChatApp — Entrar</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-zinc-950 text-gray-200 min-h-screen flex items-center justify-center">
    <div class="w-full max-w-sm px-6">
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-indigo-600 mb-3">
                <svg class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round"
                        d="M8 10h.01M12 10h.01M16 10h.01M21 16a2 2 0 01-2 2H7l-4 4V6a2 2 0 012-2h14a2 2 0 012 2v10z" />
                </svg>
            </div>
            <h1 class="text-2xl font-bold">ChatApp</h1>
        </div>

        <% if (success) { %>
            <div class="bg-emerald-600/20 border border-emerald-500 text-emerald-300 px-4 py-2 rounded-lg text-sm mb-4">
                <%= success %>
            </div>
            <% } %>
                <% if (error) { %>
                    <div class="bg-red-600/20 border border-red-500 text-red-300 px-4 py-2 rounded-lg text-sm mb-4">
                        <%= error %>
                    </div>
                    <% } %>

                        <div class="bg-zinc-900 rounded-2xl p-6 shadow-xl">
                            <div class="flex mb-5 border-b border-zinc-700">
                                <button id="loginTab"
                                    class="flex-1 pb-3 text-sm font-semibold border-b-2 border-indigo-500 text-indigo-400">Iniciar
                                    sesión</button>
                                <button id="registerTab"
                                    class="flex-1 pb-3 text-sm font-semibold border-b-2 border-transparent text-zinc-400 hover:text-zinc-200">Registrarse</button>
                            </div>

                            <form id="loginForm" action="/login" method="POST" class="space-y-4">
                                <div>
                                    <label class="block text-xs font-medium text-zinc-400 mb-1">Usuario</label>
                                    <input type="text" name="username" required autocomplete="username"
                                        class="w-full px-3 py-2 rounded-lg bg-zinc-800 border border-zinc-700 focus:border-indigo-500 focus:outline-none text-sm text-white" />
                                </div>
                                <div>
                                    <label class="block text-xs font-medium text-zinc-400 mb-1">Contraseña</label>
                                    <input type="password" name="password" required autocomplete="current-password"
                                        class="w-full px-3 py-2 rounded-lg bg-zinc-800 border border-zinc-700 focus:border-indigo-500 focus:outline-none text-sm text-white" />
                                </div>
                                <button type="submit"
                                    class="w-full py-2 bg-indigo-600 hover:bg-indigo-500 rounded-lg text-sm font-semibold transition-colors">Entrar</button>
                            </form>

                            <form id="registerForm" action="/register" method="POST" class="space-y-4 hidden">
                                <div>
                                    <label class="block text-xs font-medium text-zinc-400 mb-1">Usuario</label>
                                    <input type="text" name="username" required autocomplete="username"
                                        class="w-full px-3 py-2 rounded-lg bg-zinc-800 border border-zinc-700 focus:border-indigo-500 focus:outline-none text-sm text-white" />
                                </div>
                                <div>
                                    <label class="block text-xs font-medium text-zinc-400 mb-1">Contraseña</label>
                                    <input type="password" name="password" required autocomplete="new-password"
                                        class="w-full px-3 py-2 rounded-lg bg-zinc-800 border border-zinc-700 focus:border-indigo-500 focus:outline-none text-sm text-white" />
                                </div>
                                <button type="submit"
                                    class="w-full py-2 bg-emerald-600 hover:bg-emerald-500 rounded-lg text-sm font-semibold transition-colors">Crear
                                    cuenta</button>
                            </form>
                        </div>
    </div>

    <script>
        const loginTab = document.getElementById('loginTab');
        const registerTab = document.getElementById('registerTab');
        const loginForm = document.getElementById('loginForm');
        const registerForm = document.getElementById('registerForm');

        loginTab.addEventListener('click', () => {
            loginForm.classList.remove('hidden');
            registerForm.classList.add('hidden');
            loginTab.classList.add('border-indigo-500', 'text-indigo-400');
            loginTab.classList.remove('border-transparent', 'text-zinc-400');
            registerTab.classList.add('border-transparent', 'text-zinc-400');
            registerTab.classList.remove('border-indigo-500', 'text-indigo-400');
        });

        registerTab.addEventListener('click', () => {
            registerForm.classList.remove('hidden');
            loginForm.classList.add('hidden');
            registerTab.classList.add('border-indigo-500', 'text-indigo-400');
            registerTab.classList.remove('border-transparent', 'text-zinc-400');
            loginTab.classList.add('border-transparent', 'text-zinc-400');
            loginTab.classList.remove('border-indigo-500', 'text-indigo-400');
        });
    </script>
</body>

</html>